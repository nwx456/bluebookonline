    "test:sat-extraction": "npx tsx --test lib/sat-extraction.test.mjs",
    "test:sat-bucket-dedupe": "npx tsx --test lib/sat-bucket-dedupe.test.mjs",
    "test:sat-upload-fields": "npx tsx --test lib/sat-upload-module-fields.test.mjs",
    "test:sat-question-filter": "npx tsx --test lib/sat-question-filter.test.mjs",
    "test:sat-gemini-extract": "npx tsx --test lib/sat-gemini-extract.test.mjs",
