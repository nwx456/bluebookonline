    "test:exam-source": "npx tsx --test lib/exam-source.test.mjs",
    "test:exam-source-url": "npx tsx --test lib/exam-source-url-verify.test.mjs",
    "test:safe-redirect": "npx tsx --test lib/safe-redirect.test.mjs",
    "test:class-code": "npx tsx --test lib/class-code.test.mjs",
    "test:class-access": "npx tsx --test lib/class-access.test.mjs",
    "test:late-submission": "npx tsx --test lib/late-submission.test.mjs",
    "test:assign-content-filters": "npx tsx --test lib/assign-content-filters.test.mjs",
    "test:resource-publish": "npx tsx --test lib/resource-publish-utils.test.mjs",
    "test:teacher-assignment-content": "npx tsx --test lib/teacher-assignment-content.test.mjs",
    "test:classes": "npm run test:class-code && npm run test:class-access && npm run test:late-submission",
    "test:sat": "npm run test:sat-gemini-extract && npm run test:sat-ap-style && npm run test:sat-single-shot && npm run test:sat-extract-pipeline && npm run test:sat-extraction && npm run test:sat-upload-fields && npm run test:upload-progress && npm run test:sat-normalizer && npm run test:sat-display && npm run test:sat-ingest && npm run test:sat-bucket-dedupe && npm run test:sat-question-filter && npm run test:sat-exam-grade && npm run test:sat-pdf-eval",
    "eval:sat": "npx tsx --env-file=.env.local scripts/sat-pdf-eval.mjs",
    "eval:sat:live": "npx tsx --env-file=.env.local scripts/sat-pdf-eval.mjs --live",
    "test:sat-smoke": "node --env-file=.env scripts/sat-module-flow-smoke.mjs",
    "db:push": "supabase db push",
    "db:migration:list": "supabase migration list"
