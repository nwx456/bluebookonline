    "pdfjs-dist": "^5.4.624",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.9.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^2.5.5",
    "tw-animate-css": "^1.4.0"
