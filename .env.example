# Copy to .env.local and fill in values. Next.js loads .env.local over .env.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site URL (local dev) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Outbound mail (pick ONE provider) ---

# Option A: Google Workspace SMTP (recommended for apracticexamonline.com)
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@apracticexamonline.com
SMTP_PASS=16charapppassword
MAIL_FROM_EMAIL=info@apracticexamonline.com
MAIL_FROM_NAME=AP Practice Exam Online
# Alternative: SMTP_PORT=465 and SMTP_SECURE=true

# Option B: Resend (alternative for production custom domain)
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_...
# MAIL_FROM_EMAIL=info@apracticexamonline.com
# MAIL_FROM_NAME=AP Practice Exam Online

# Option C: Personal Gmail (dev only — must be @gmail.com or Google Workspace mailbox)
# MAIL_PROVIDER=gmail
# GMAIL_USER=yourname@gmail.com
# GMAIL_APP_PASSWORD=16charapppassword
# MAIL_FROM_NAME=AP Practice Exam Online

# Option D: Other custom SMTP
# MAIL_PROVIDER=smtp
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM_EMAIL=info@apracticexamonline.com

# --- AI (required for PDF analysis) ---
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# --- Admin mail worker (optional) ---
# MAIL_WORKER_SECRET=
# ADMIN_MAIL_DAILY_RECIPIENT_CAP=0
# ADMIN_MAIL_HOURLY_RECIPIENT_CAP=0
