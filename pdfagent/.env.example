# --- Ana site entegrasyonu (sadece HTTP üzerinden konuşur) ---
MAIN_APP_URL=http://www.apbluebookonline.com
MAIN_APP_BOT_EMAIL=info@apbluebookonline.com

# --- Postgres (pdfagent kendi DB'si) ---
DATABASE_URL=postgresql://pdfagent:pdfagent@localhost:5432/pdfagent

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Admin paneli (ilk admin seed) ---
ADMIN_INIT_EMAIL=info@apbluebookonline.com
ADMIN_INIT_PASSWORD=Ayberk7606.
JWT_SECRET=change-this-to-a-random-32+-char-string

# --- Davranış ---
# Ana siteye gönderim hızı (dakikada kaç istek)
UPLOAD_RATE_PER_MIN=2
# Doğrulama limiti
MAX_PDF_BYTES=52428800
# Discover cron schedule (her 6 saatte bir varsayılan)
DISCOVER_CRON=0 */6 * * *
# Auto-approve KAPALI (manuel onay)
AUTO_APPROVE=false

# --- Worker davranışı ---
NODE_ENV=development
